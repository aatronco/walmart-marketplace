# Copy this file to .env and fill in your credentials. Never commit .env.

# Jumpseller store credentials (Settings → API)
JUMPSELLER_LOGIN=your_login
JUMPSELLER_AUTH_TOKEN=your_auth_token

# Webhook HMAC secret — generate with: ruby -e "require 'securerandom'; puts SecureRandom.hex(32)"
JUMPSELLER_WEBHOOK_SECRET=your_webhook_secret

# Dashboard password (HTTP Basic Auth — username is ignored, only password matters)
# Optional: leave unset to disable the password prompt (local use only —
# always set a password on a public deployment, or /sync is open to anyone)
DASHBOARD_PASSWORD=your_dashboard_password

# Walmart Marketplace Chile credentials (Seller Center → API Keys)
# Set WALMART_ENV=sandbox for testing, production for live
WALMART_CLIENT_ID=your_client_id
WALMART_CLIENT_SECRET=your_client_secret
WALMART_ENV=production

# Optional — override default Walmart Chile category for unmapped products
WALMART_DEFAULT_CATEGORY=Decoración de Hogar, Cocina y Otros

# Identifies this integration to Walmart Chile (do not change)
WALMART_CHANNEL_TYPE=Jumpseller

# Inventory safety buffer (optional — defaults shown)
# STOCK_BUFFER=5    # minimum units in Jumpseller before showing any stock on Walmart
# STOCK_DIVISOR=5   # stock shown on Walmart = floor(jumpseller_stock / STOCK_DIVISOR)
